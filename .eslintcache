orCount":0,"fixableWarningCount":0},"C:\\Projects\\exterra\\src\\index.js",[],["129","130"],"C:\\Projects\\exterra\\src\\App.js",[],"C:\\Projects\\exterra\\src\\styles\\GlobalStyle.js",[],"C:\\Projects\\exterra\\src\\components\\map\\Map.js",["131","132"],"C:\\Projects\\exterra\\src\\components\\map\\LaunchMarker.js",[],"C:\\Projects\\exterra\\src\\components\\layout\\Header.js",[],"C:\\Projects\\exterra\\src\\styles\\theme.js",[],"C:\\Projects\\exterra\\src\\styles\\mixins.js",[],"C:\\Projects\\exterra\\src\\utils\\index.js",["133"],"import { DateTime } from \"luxon\";\r\nimport _ from 'lodash';\r\n\r\nexport const getCountdown = (launchDateTime) => {\r\n  const { milliseconds } = DateTime.fromISO(launchDateTime).diff(DateTime.local(), ['days', 'milliseconds']).toObject();\r\n  const value = DateTime.fromMillis(Math.abs(milliseconds)).toFormat('TT')\r\n\r\n  return value;\r\n}\r\n\r\nexport const groupByLocation = (launchArr) => {\r\n  const withLaunchSite = launchArr.map(launch => {\r\n    return { ...launch, launchSite: Math.abs(parseInt(launch.pad.latitude) + parseInt(launch.pad.longitude)) }\r\n  });\r\n\r\n  const launchesGrouped = _.groupBy(withLaunchSite, 'launchSite');\r\n\r\n  const single = [];\r\n  const multiple = [];\r\n\r\n  Object.values(launchesGrouped).map(launch => {\r\n    if (launch.length === 1) {\r\n      single.push(launch[0]);\r\n    } else {\r\n      multiple.push(launch)\r\n    }\r\n  })\r\n\r\n  return [[...single], multiple];\r\n}","C:\\Projects\\exterra\\src\\pages\\LaunchDetails.js",["134"],"import { useEffect, useState } from 'react';\r\nimport styled from 'styled-components';\r\n\r\nimport Mission from '../components/sections/Mission';\r\nimport Agency from '../components/sections/Agency';\r\nimport StatusBar from '../components/StatusBar';\r\nimport Time from '../components/Time';\r\nimport Rocket from '../components/sections/Rocket';\r\nimport Pad from '../components/sections/Pad';\r\nimport { getLaunchById } from '../api';\r\n\r\n\r\nconst StyledImgContainer = styled.div`\r\n  ${props => props.theme.mixins.imgContainer}\r\n  height: 500px;\r\n`;\r\n\r\nexport default function LaunchDetails({ match }) {\r\n  const [launch, setLaunch] = useState('');\r\n\r\n  useEffect(() => {\r\n    getLaunchById(match.params.id)\r\n      .then(data => setLaunch(data))\r\n  }, []);\r\n\r\n  if (!launch) return <div></div>;\r\n\r\n  return (\r\n    <main>\r\n      <StatusBar agency={launch.launch_service_provider} mission={launch.mission} status={launch.status} />\r\n      <div className=\"flex flex-col sm:flex-row sm:justify-between mt-4 sm:mt-6 mb-2\">\r\n        <h1>{launch.name}</h1>\r\n        <div className=\"h-auto text-xl order-1 mb-4 sm:mb-0 sm:ml-auto\"><Time launchTime={launch.net} /></div>\r\n      </div>\r\n      <div className=\"flex text-opacity text-xs sm:text-sm\">\r\n        <span className=\"mr-6\">{launch.launch_service_provider.name.length < 25 ? launch.launch_service_provider.name : launch.launch_service_provider.abbrev}</span>\r\n        <span>{launch.pad.location.name}</span>\r\n      </div>\r\n      {launch.mission && (\r\n        <p className=\"my-6\" dangerouslySetInnerHTML={{ __html: launch.mission.description.replace(/(?:\\r\\n|\\r|\\n)/g, '<br>') }}></p>\r\n      )}\r\n      <StyledImgContainer className=\"my-12\">\r\n        <img src={launch.image} alt={launch.name} />\r\n      </StyledImgContainer>\r\n      {launch.mission ? <Mission mission={launch.mission} /> : null}\r\n      <Agency agency={launch.launch_service_provider} />\r\n      <Rocket rocket={launch.rocket} />\r\n      <Pad pad={launch.pad} />\r\n    </main>\r\n  )\r\n}\r\n","C:\\Projects\\exterra\\src\\pages\\LaunchMap.js",[],"C:\\Projects\\exterra\\src\\components\\StatusBar.js",[],"C:\\Projects\\exterra\\src\\components\\Time.js",["135","136"],"import { useEffect, useState } from 'react';\r\nimport { DateTime } from 'luxon';\r\n\r\nimport { getCountdown } from '../utils';\r\n\r\nconst Time = ({ launchTime }) => {\r\n  const [time, setTime] = useState('');\r\n\r\n  const launch = DateTime.fromISO(launchTime);\r\n  const { hours } = DateTime.fromISO(launchTime).diff(DateTime.local(), ['hours']).toObject();\r\n\r\n  useEffect(() => {\r\n    Math.abs(hours) < 24 ? setTime(getCountdown(launchTime)) : setTime(launch.toFormat('DD'));\r\n  }, []);\r\n\r\n  useEffect(() => {\r\n    if (Math.abs(hours) > 24) return;\r\n\r\n    const interval = setInterval(() => {\r\n      setTime(getCountdown(launchTime));\r\n    }, 1000);\r\n\r\n    return () => clearInterval(interval);\r\n  }, [time]);\r\n\r\n  if (!time) return <div></div>;\r\n\r\n  return (\r\n    <div className=\"whitespace-nowrap font-semibold\">\r\n      <span className=\"text-opacity mr-2\">{Math.sign(hours) === 1 ? 'T-' : 'T+'}</span><time>{time}</time>\r\n    </div>\r\n  )\r\n}\r\n\r\nexport default Time;","C:\\Projects\\exterra\\src\\components\\sections\\Mission.js",[],"C:\\Projects\\exterra\\src\\components\\sections\\Agency.js",[],"C:\\Projects\\exterra\\src\\components\\sections\\Rocket.js",[],"C:\\Projects\\exterra\\src\\components\\sections\\Pad.js",[],"C:\\Projects\\exterra\\src\\components\\ProgressBar.js",[],"C:\\Projects\\exterra\\src\\config.js",[],"C:\\Projects\\exterra\\src\\api\\index.js",[],"C:\\Projects\\exterra\\src\\components\\map\\LaunchMarkerMultple.js",[],"C:\\Projects\\exterra\\src\\pages\\Rockets.js",["137"],"import { useEffect, useRef, useState } from 'react';\r\nimport { Link } from 'react-router-dom';\r\nimport styled from 'styled-components';\r\n\r\nimport { getRockets } from '../api';\r\nimport RocketItem from '../components/RocketItem';\r\n\r\nconst StyledLinkDiv = styled.div`\r\n  border: 1px dotted var(--white-opacity-2);\r\n`;\r\n\r\nexport default function Rockets() {\r\n  const [rockets, setRockets] = useState([]);\r\n  const [offset, setOffset] = useState(0);\r\n  const [compare, setCompare] = useState([]);\r\n\r\n  const loader = useRef(null);\r\n\r\n  useEffect(() => {\r\n    getRockets(offset)\r\n      .then(data => setRockets([...rockets, ...data.results]))\r\n  }, [offset]);\r\n\r\n  useEffect(() => {\r\n    const observer = new IntersectionObserver(handleObserver, { root: null, rootMargin: \"20px\", threshold: 1.0 });\r\n    \r\n    if (loader.current) {\r\n      observer.observe(loader.current)\r\n    }\r\n  }, []);\r\n  \r\n  const handleObserver = (entities) => {\r\n    const target = entities[0];\r\n    if (target.isIntersecting) {\r\n      setOffset((offset) => offset + 50)\r\n    }\r\n  }\r\n\r\n  if (!rockets) return <div></div>;\r\n\r\n  return (\r\n    <main>\r\n      <div className=\"flex flex-grow-0 justify-between items-center mb-8\">\r\n        <h1>Rockets</h1>\r\n        {compare.length > 1 && (\r\n          <StyledLinkDiv>\r\n            <Link to={`/rockets/compare/${compare[0]}-vs-${compare[1]}`} className=\"flex items-center font-semibold ml-2\">Compare<i className=\"material-icons mt-1\">navigate_next</i></Link>\r\n          </StyledLinkDiv>\r\n        )}\r\n      </div>\r\n      <div>\r\n        {rockets.map(rocket => <RocketItem rocket={rocket} setCompare={setCompare} locked={compare.length > 1} />)}\r\n      </div>\r\n      <div className=\"loading\" ref={loader}>Loading...</div>\r\n    </main>\r\n  )\r\n}\r\n","C:\\Projects\\exterra\\src\\components\\RocketItem.js",[],"C:\\Projects\\exterra\\src\\pages\\RocketCompare.js",["138"],"import { useEffect, useState } from 'react';\r\nimport styled from 'styled-components';\r\nimport { DateTime } from 'luxon';\r\n\r\nimport { getRocketById } from '../api';\r\n\r\nconst StyledRow = styled.div.attrs({ className: 'row-border py-3 md:p-3 font-medium text-xs sm:text-sm md:text-base' })`\r\n  ${props => props.theme.mixins.row}\r\n  display: grid;\r\n  grid-template-columns: 1fr auto 1fr;\r\n\r\n  *:nth-child(1) {\r\n      text-align: left;\r\n  }\r\n\r\n  *:nth-child(2) {\r\n    text-align: right;\r\n  }\r\n\r\n  .label {  \r\n    ${props => props.theme.mixins.label}\r\n    grid-column: 2;\r\n    grid-row: 1;\r\n  }\r\n`;\r\n\r\nconst StyledImgContainer = styled.div`\r\n  ${props => props.theme.mixins.imgContainer}\r\n  height: 540px;\r\n  \r\n  @media(max-width: 480px) {\r\n    height: 384px;\r\n  }\r\n`;\r\n\r\nconst StyledSectionHeader = styled.h2`\r\n  ${props => props.theme.mixins.sectionH2}\r\n`;\r\n\r\nexport default function RocketCompare({ match }) {\r\n  const [rocketA, setRocketA] = useState({});\r\n  const [rocketB, setRocketB] = useState({});\r\n\r\n  const rockets = [rocketA, rocketB];\r\n\r\n  const compareIds = match.params.compare.split('-vs-').map(num => parseInt(num));\r\n\r\n  useEffect(() => {\r\n    getRocketById(compareIds[0])\r\n      .then(data => setRocketA(data));\r\n\r\n    getRocketById(compareIds[1])\r\n      .then(data => setRocketB(data));\r\n  }, []);\r\n\r\n  if (!rocketA && !rocketB) return <div></div>;\r\n\r\n  return (\r\n    <main>\r\n      <div className=\"grid grid-cols-2 gap-4 sm:gap-12\">\r\n        {rockets.map(rocket => <StyledImgContainer><img src={rocket.image_url} alt={rocket.name} /></StyledImgContainer>)}\r\n      </div>\r\n      <div className=\"grid grid-cols-2 gap-12 py-6\">\r\n        {rockets.map(rocket => <div className=\"text-center font-bold text-xxl sm:text-heading\">{rocket.name}</div>)}\r\n      </div>\r\n      <section>\r\n        <StyledSectionHeader>Details <span className=\"hl\"></span></StyledSectionHeader>\r\n        <StyledRow>\r\n          {rockets.map(rocket => <span>{rocket.full_name}</span>)}\r\n          <div className=\"label\">Full Name</div>\r\n        </StyledRow>\r\n        <StyledRow>\r\n          {rockets.map(rocket => <span>{rocket.family}</span>)}\r\n          <div className=\"label\">Family</div>\r\n        </StyledRow>\r\n        <StyledRow>\r\n          {rockets.map(rocket => <span>{rocket.variant}</span>)}\r\n          <div className=\"label\">Variant</div>\r\n        </StyledRow>\r\n        <StyledRow>\r\n          {rockets.map(rocket => <span>{rocket.manufacturer ? rocket.manufacturer.name : ''}</span>)}\r\n          <div className=\"label\">Manufacturer</div>\r\n        </StyledRow>\r\n        <StyledRow className=\"row-border-btm\">\r\n          {rockets.map(rocket => <span>{DateTime.fromISO(rocket.maiden_flight).toLocaleString(DateTime.DATE_MED)}</span>)}\r\n          <div className=\"label\">Maiden flight</div>\r\n        </StyledRow>\r\n      </section>\r\n      <section>\r\n        <StyledSectionHeader>Specification <span className=\"hl\"></span></StyledSectionHeader>\r\n        <StyledRow>\r\n          {rockets.map(rocket => <span>{rocket.max_stage}</span>)}\r\n          <div className=\"label\">Stages</div>\r\n        </StyledRow>\r\n        <StyledRow>\r\n          {rockets.map(rocket => <><span>{rocket.length}<span className=\"unit\">m</span></span></>)}\r\n          <div className=\"label\">Length</div>\r\n        </StyledRow>\r\n        <StyledRow>\r\n          {rockets.map(rocket => <span>{rocket.diameter}<span className=\"unit\">m</span></span>)}\r\n          <div className=\"label\">Diameter</div>\r\n        </StyledRow>\r\n        <StyledRow>\r\n          {rockets.map(rocket => <span>{(rocket.launch_mass * 1000).toString().replace(/\\B(?=(\\d{3})+(?!\\d))/g, \",\")}<span className=\"unit\">T</span></span>)}\r\n          <div className=\"label\">Launch Mass</div>\r\n        </StyledRow>\r\n        <StyledRow className=\"row-border-btm\">\r\n          {rockets.map(rocket => <span>{rocket.thrust ? (rocket.to_thrust).toString().replace(/\\B(?=(\\d{3})+(?!\\d))/g, \",\") : '-'}<span className=\"unit\">kN</span></span>)}\r\n          <div className=\"label\">Thrust</div>\r\n        </StyledRow>\r\n      </section>\r\n      <section>\r\n        <StyledSectionHeader>Payload Capacity <span className=\"hl\"></span></StyledSectionHeader>\r\n        <StyledRow>\r\n          {rockets.map(rocket => <span>{rocket.gto_capacity ? (rocket.gto_capacity).toString().replace(/\\B(?=(\\d{3})+(?!\\d))/g, \",\") : '-'}<span className=\"unit\">kg</span></span>)}\r\n          <div className=\"label\">GTO</div>\r\n        </StyledRow>\r\n        <StyledRow className=\"row-border-btm\">\r\n          {rockets.map(rocket => <span>{rocket.leo_capacity ? (rocket.leo_capacity).toString().replace(/\\B(?=(\\d{3})+(?!\\d))/g, \",\") : '-'}<span className=\"unit\">kg</span></span>)}\r\n          <div className=\"label\">LEO</div>\r\n        </StyledRow>\r\n      </section>\r\n      <section>\r\n        <StyledSectionHeader>Launch Statistics <span className=\"hl\"></span></StyledSectionHeader>\r\n        <StyledRow>\r\n          {rockets.map(rocket => <span>{rocket.successful_launches}</span>)}\r\n          <div className=\"label\">Success</div>\r\n        </StyledRow>\r\n        <StyledRow className=\"row-border-btm\">\r\n          {rockets.map(rocket => <span>{rocket.failed_launches}</span>)}\r\n          <div className=\"label\">Fail</div>\r\n        </StyledRow>\r\n      </section>\r\n    </main>\r\n  )\r\n}\r\n","C:\\Projects\\exterra\\src\\components\\layout\\Menu.js",[],"C:\\Projects\\exterra\\src\\pages\\Upcoming.js",[],"C:\\Projects\\exterra\\src\\pages\\Previous.js",["139","140","141","142","143","144"],"import { useRef } from 'react';\r\nimport { useState, useEffect } from 'react';\r\nimport { Link } from 'react-router-dom';\r\nimport styled from 'styled-components';\r\nimport { flattenDeep } from 'lodash';\r\n\r\nimport { getPreviousLaunches } from '../api';\r\nimport StatusBar from '../components/StatusBar';\r\nimport Time from '../components/Time';\r\nimport LaunchItem from '../components/LaunchItem';\r\n\r\nconst StyledBtnDiv = styled.div`\r\n  ${props => props.theme.mixins.btn}\r\n`;\r\n\r\nexport default function Previous() {\r\n  const [previous, setPrevious] = useState([]);\r\n  const [offset, setOffset] = useState(50);\r\n\r\n  const loader = useRef(null);\r\n\r\n  useEffect(() => {\r\n    getPreviousLaunches(offset)\r\n      .then(data => setPrevious([...previous, ...data.results.filter(launch => launch.status.abbrev !== 'TBD')]));\r\n  }, [offset]);\r\n\r\n  useEffect(() => {\r\n    const observer = new IntersectionObserver(handleObserver, { root: null, rootMargin: \"20px\", threshold: 1.0 });\r\n    \r\n    if (loader.current) {\r\n      observer.observe(loader.current)\r\n    }\r\n  }, []);\r\n  \r\n  const handleObserver = (entities) => {\r\n    const target = entities[0];\r\n    if (target.isIntersecting) {\r\n      setOffset((offset) => offset + 50)\r\n    }\r\n  }\r\n\r\n  if (!previous) return <div></div>;\r\n\r\n  return (\r\n    <main>\r\n      <div className=\"flex items-center justify-between mb-6 sm:mb-12\">\r\n        <h1>Previous Launches</h1>\r\n      </div>\r\n      <section>\r\n        {previous.map(launch => (\r\n         <LaunchItem launch={launch} />\r\n        ))}\r\n      </section>\r\n      <div className=\"loading\" ref={loader}>Loading...</div>\r\n    </main>\r\n  )\r\n}","C:\\Projects\\exterra\\src\\components\\LaunchMapItem.js",[],"C:\\Projects\\exterra\\src\\components\\LaunchItem.js",[],"C:\\Projects\\exterra\\src\\components\\LaunchMapList.js",[],{"ruleId":"145","replacedBy":"146"},{"ruleId":"147","replacedBy":"148"},{"ruleId":"149","severity":1,"message":"150","line":1,"column":32,"nodeType":"151","messageId":"152","endLine":1,"endColumn":38},{"ruleId":"149","severity":1,"message":"153","line":1,"column":40,"nodeType":"151","messageId":"152","endLine":1,"endColumn":48},{"ruleId":"154","severity":1,"message":"155","line":21,"column":45,"nodeType":"156","messageId":"157","endLine":21,"endColumn":47},{"ruleId":"158","severity":1,"message":"159","line":24,"column":6,"nodeType":"160","endLine":24,"endColumn":8,"suggestions":"161"},{"ruleId":"158","severity":1,"message":"162","line":14,"column":6,"nodeType":"160","endLine":14,"endColumn":8,"suggestions":"163"},{"ruleId":"158","severity":1,"message":"164","line":24,"column":6,"nodeType":"160","endLine":24,"endColumn":12,"suggestions":"165"},{"ruleId":"158","severity":1,"me